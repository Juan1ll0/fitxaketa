{
	"threshold": 2,
	"minLines": 10,
	"minTokens": 70,
	"format": ["typescript", "javascript", "markup"],
	"formatsExts": {
		"markup": ["svelte", "html"]
	},
	"ignore": [
		"**/node_modules/**",
		"**/.svelte-kit/**",
		"**/build/**",
		"**/dist/**",
		"**/*.test.ts",
		"**/*.test.svelte.ts",
		"**/e2e/**"
	],
	"absolute": true,
	"gitignore": true
}
